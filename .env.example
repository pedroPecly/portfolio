# Resend API key (keep secret, do not commit your real .env)
RESEND_API_KEY=

# Email that will receive contact messages
CONTACT_RECEIVER=your_email@example.com

# Sender address used by Resend
# Sandbox: keep onboarding@resend.dev
# Production: use an address from a verified domain
CONTACT_SENDER="Portfolio <onboarding@resend.dev>"

# Cloudflare Turnstile (anti-spam)
# Create keys at https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
